{
  "name": "healthbridge-mcp",
  "version": "1.0.0",
  "description": "HealthBridge - Clinical Decision Support MCP Server for Healthcare AI",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "serve": "tsx src/http-transport.ts",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
